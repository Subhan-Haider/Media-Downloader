{
  "name": "focus-flow",
  "version": "1.0.0",
  "description": "A premium Pomodoro Timer application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win appx"
  },
  "keywords": [
    "pomodoro",
    "timer",
    "productivity"
  ],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.focusflow.app",
    "productName": "FocusFlow",
    "win": {
      "target": "appx"
    },
    "appx": {
      "identityName": "FocusFlow",
      "publisher": "CN=YourPublisherName",
      "publisherDisplayName": "Your Publisher Name",
      "applicationId": "FocusFlow"
    }
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.15.3"
  }
}
